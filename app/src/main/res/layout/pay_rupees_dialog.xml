<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Amount in Rs."
        android:textSize="@dimen/_13sdp"
        android:textStyle="italic"
        android:layout_marginLeft="@dimen/_125sdp"
        android:textColor="@color/color_black"/>

    <LinearLayout
        android:id="@+id/liCredit"
        android:layout_below="@+id/liText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginLeft="@dimen/_10sdp"
        android:layout_marginStart="@dimen/_10sdp"
        android:layout_marginEnd="@dimen/_10sdp"
        android:layout_marginBottom="@dimen/_10sdp"
        tools:ignore="MissingConstraints">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="@dimen/_30sdp"
                android:text="Add Credit : "
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="@dimen/_20sdp"
                android:layout_gravity="center_vertical"
                android:gravity="center_vertical"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="@dimen/_30sdp"
                android:text="(Rs. 100/Report) "
                android:textColor="#000000"
                android:textSize="@dimen/_12sdp"
                android:textStyle="italic"
                android:layout_gravity="center_vertical"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/_minus10sdp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="@dimen/_140sdp"
            android:layout_height="wrap_content"
            android:background="@drawable/add_crtedit_layout"
            android:layout_margin="@dimen/_3sdp">

            <ImageView
                android:id="@+id/imgMinus"
                android:layout_width="@dimen/_10sdp"
                android:layout_height="@dimen/_30sdp"
                android:src="@drawable/line"
                android:layout_marginLeft="@dimen/_8sdp"
                android:layout_weight="1"
                android:layout_gravity="center_vertical"/>

            <View
                android:layout_width="@dimen/_1sdp"
                android:layout_height="@dimen/_40sdp"
                android:background="#000000"
                android:layout_marginLeft="@dimen/_8sdp"/>

            <TextView
                android:id="@+id/txtCreditAdd"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/_40sdp"
                android:text="100"
                android:layout_marginEnd="@dimen/_8sdp"
                android:textSize="@dimen/_15sdp"
                android:textAlignment="center"
                android:gravity="center"
                android:layout_marginLeft="@dimen/_5sdp"
                android:layout_weight="1"/>

            <View
                android:layout_width="@dimen/_1sdp"
                android:layout_height="@dimen/_40sdp"
                android:background="#000000"/>

            <ImageView
                android:id="@+id/imgPlus"
                android:layout_width="@dimen/_10sdp"
                android:layout_height="@dimen/_30sdp"
                android:src="@drawable/plus"
                android:layout_marginLeft="@dimen/_8sdp"
                android:layout_marginEnd="@dimen/_8sdp"
                android:tint="#000000"
                android:paddingLeft="@dimen/_8sdp"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"/>

        </LinearLayout>

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="*T &amp; C apply"
        android:textSize="@dimen/_12sdp"
        android:layout_gravity="end"
        android:layout_marginTop="@dimen/_minus18sdp"
        android:layout_marginEnd="@dimen/_12sdp"
        android:textStyle="italic"
        android:textColor="@color/color_black"/>

    <Button
        android:id="@+id/btnPay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_5sdp"
        android:text="Pay now"
        android:clickable="false"
        android:background="@drawable/new_main_activity_button_background"
        android:textColor="#FFFFFF"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="@dimen/_50sdp"
        android:layout_marginLeft="@dimen/_10sdp"
        android:layout_marginRight="@dimen/_10sdp"/>

</LinearLayout>